// Planning Complexity Detection & Routing Flow
// Authoritative process definition — prose in SKILL.md supports, doesn't replace.
//
// Render: dot -Tsvg planning-flow.dot -o planning-flow.svg

digraph planning_flow {
    rankdir=TB;
    node [shape=box, style=rounded, fontname="Helvetica", fontsize=11];
    edge [fontname="Helvetica", fontsize=9];

    // Entry
    start [label="Planning\nRequested", shape=ellipse, style=filled, fillcolor="#e8f5e9"];

    // Assessment
    read_req [label="Read Requirements\n& Context"];
    check_knowledge [label="Check Knowledge Base\n(.knowledge/ ADRs, patterns)"];
    assess [label="Assess Complexity"];

    // Complexity decision
    complexity [label="Complexity\nLevel?", shape=diamond, style=filled, fillcolor="#fff3e0"];

    // Routes
    fast [label="/plan:fast\nSingle-phase, no research"];
    standard [label="/plan\nStandard multi-phase"];
    deep [label="/plan:deep\nResearch + analysis"];
    parallel [label="/plan:parallel\nFile ownership matrix"];

    // Sub-decisions
    multi_module [label="Multi-module\nor parallel?", shape=diamond, style=filled, fillcolor="#fff3e0"];
    unknowns [label="Significant\nunknowns?", shape=diamond, style=filled, fillcolor="#fff3e0"];

    // Plan creation
    create_plan [label="Create Plan\n(12-section format)"];
    validate [label="Validate Plan\n(/plan:validate)"];
    validated [label="Plan\nValid?", shape=diamond, style=filled, fillcolor="#fff3e0"];
    revise [label="Revise Plan\n(address gaps)"];

    // Output
    done [label="Plan Ready\nfor Implementation", shape=ellipse, style=filled, fillcolor="#e8f5e9"];

    // Flow
    start -> read_req;
    read_req -> check_knowledge;
    check_knowledge -> assess;
    assess -> complexity;

    complexity -> fast [label="Simple:\n1 file, clear task"];
    complexity -> unknowns [label="Medium:\nmulti-file"];
    complexity -> deep [label="Complex:\nnew domain"];

    unknowns -> standard [label="No"];
    unknowns -> deep [label="Yes"];

    fast -> create_plan;
    standard -> multi_module;
    deep -> create_plan;

    multi_module -> parallel [label="Yes"];
    multi_module -> create_plan [label="No"];
    parallel -> create_plan;

    create_plan -> validate;
    validate -> validated;
    validated -> done [label="Pass"];
    validated -> revise [label="Gaps found"];
    revise -> validate;
}
