{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Session Metrics Entry",
  "description": "Schema for auto-improvement session metrics stored in .kit-data/improvements/sessions.jsonl",
  "type": "object",
  "required": ["sessionId", "timestamp", "branch"],
  "properties": {
    "sessionId": {
      "type": "string",
      "description": "Unique session identifier"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp when session ended"
    },
    "duration_ms": {
      "type": "number",
      "description": "Session duration in milliseconds"
    },
    "branch": {
      "type": "string",
      "description": "Git branch name at session end"
    },
    "tasks": {
      "type": "object",
      "properties": {
        "total": { "type": "number", "default": 0 },
        "completed": { "type": "number", "default": 0 },
        "failed": { "type": "number", "default": 0 }
      }
    },
    "errors": {
      "type": "object",
      "properties": {
        "count": { "type": "number", "default": 0 },
        "types": {
          "type": "array",
          "items": { "type": "string", "enum": ["build", "test", "lint", "runtime"] }
        }
      }
    },
    "rework": {
      "type": "object",
      "properties": {
        "fixIterations": { "type": "number", "default": 0 },
        "verificationFailures": { "type": "number", "default": 0 }
      }
    },
    "git": {
      "type": "object",
      "properties": {
        "filesChanged": { "type": "number", "default": 0 },
        "insertions": { "type": "number", "default": 0 },
        "deletions": { "type": "number", "default": 0 }
      }
    },
    "skills": {
      "type": "object",
      "properties": {
        "discovered": { "type": "array", "items": { "type": "string" } },
        "loaded": { "type": "array", "items": { "type": "string" } },
        "unused": { "type": "array", "items": { "type": "string" } }
      }
    },
    "knowledge": {
      "type": "object",
      "properties": {
        "retrieved": { "type": "number", "default": 0 },
        "captured": { "type": "number", "default": 0 },
        "staleHits": { "type": "number", "default": 0 }
      }
    },
    "routing": {
      "type": "object",
      "properties": {
        "intent": { "type": "string" },
        "command": { "type": "string" },
        "platform": { "type": "string" }
      }
    }
  }
}
