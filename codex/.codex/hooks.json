{
    "hooks":  {
                  "SessionStart":  [
                                       {
                                           "matcher":  "startup|resume",
                                           "hooks":  [
                                                         {
                                                             "type":  "command",
                                                             "command":  "node \"$(git rev-parse --show-toplevel)/.codex/hooks/session-init.cjs\"",
                                                             "statusMessage":  "Initializing tri-ai-kit runtime"
                                                         }
                                                     ]
                                       }
                                   ],
                  "PreToolUse":  [
                                     {
                                         "matcher":  "Bash",
                                         "hooks":  [
                                                       {
                                                           "type":  "command",
                                                           "command":  "node \"$(git rev-parse --show-toplevel)/.codex/hooks/scout-block.cjs\"",
                                                           "statusMessage":  "Checking Bash command scope"
                                                       },
                                                       {
                                                           "type":  "command",
                                                           "command":  "node \"$(git rev-parse --show-toplevel)/.codex/hooks/privacy-block.cjs\"",
                                                           "statusMessage":  "Checking sensitive paths"
                                                       }
                                                   ]
                                     },
                                     {
                                         "matcher":  "Bash",
                                         "hooks":  [
                                                       {
                                                           "type":  "command",
                                                           "command":  "node \"$(git rev-parse --show-toplevel)/.codex/hooks/build-gate-hook.cjs\"",
                                                           "statusMessage":  "Checking build gate"
                                                       }
                                                   ]
                                     }
                                 ],
                  "UserPromptSubmit":  [
                                           {
                                               "hooks":  [
                                                             {
                                                                 "type":  "command",
                                                                 "command":  "node \"$(git rev-parse --show-toplevel)/.codex/hooks/context-reminder.cjs\"",
                                                                 "statusMessage":  "Injecting project context"
                                                             }
                                                         ]
                                           }
                                       ],
                  "Stop":  [
                               {
                                   "hooks":  [
                                                 {
                                                     "type":  "command",
                                                     "command":  "node \"$(git rev-parse --show-toplevel)/.codex/hooks/session-metrics.cjs\" 2\u003e/dev/null || true",
                                                     "statusMessage":  "Writing session metrics"
                                                 },
                                                 {
                                                     "type":  "command",
                                                     "command":  "node \"$(git rev-parse --show-toplevel)/.codex/hooks/lesson-capture.cjs\" 2\u003e/dev/null || true",
                                                     "statusMessage":  "Capturing session lessons"
                                                 },
                                                 {
                                                     "type":  "command",
                                                     "command":  "node \"$(git rev-parse --show-toplevel)/.codex/hooks/notifications/notify.cjs\" 2\u003e/dev/null || true",
                                                     "statusMessage":  "Sending notifications"
                                                 }
                                             ]
                               }
                           ]
              }
}
