# tri_ai_kit - ScoutBlock ignore patterns
# Blocks directories with heavy file counts that fill LLM context
# Syntax: gitignore-spec | Use ! prefix to allow (e.g., !src/vendor)

# JS/TS
node_modules
dist
build
.next
.nuxt
.turbo
.vercel
.cache

# Python
__pycache__
.venv
venv

# Go/PHP/Rust/Java
vendor
target

# iOS / Xcode
DerivedData
*.xcarchive
Pods
*.framework
*.dSYM

# Android
.gradle

# VCS & Coverage
.git
coverage
.nyc_output
